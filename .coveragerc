[run]
# Onde a cobertura deve olhar (apenas código novo)
source = app

# Omitir arquivos que não queremos medir
omit =
    */__init__.py
    app/tests/*
    sistemas/*
    venv/*
    *.pyc
    app/core/config.py
    verify_*.py

[report]
# Ignorar linhas que não devem ser testadas (ex: if __name__ == "__main__":)
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
    ...